# ── FlashScore / RapidAPI ─────────────────────────────────────────────────────
RAPID_API_KEY=your-rapidapi-key-here
FLASHSCORE_API_HOST=flashscore4.p.rapidapi.com
FLASHSCORE_API_BASE_URL=https://flashscore4.p.rapidapi.com
