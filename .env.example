# ── Core Django ──────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=51.255.1.140,yourdomain.com,localhost

# ── Database ─────────────────────────────────────────────────────────────────
# For docker-compose local:
DATABASE_URL=postgres://kicktips:yourpassword@db:5432/kicktips
# For Coolify (uses internal service name):
# DATABASE_URL=postgres://kicktips:yourpassword@kicktips-db:5432/kicktips

DB_PASSWORD=yourpassword

# ── Timezone ──────────────────────────────────────────────────────────────────
